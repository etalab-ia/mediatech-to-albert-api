ALBERT_API_URL=
ALBERT_API_TOKEN=your_albert_api_token_here

HUGGINGFACE_TOKEN=your_huggingface_token_here

# Database (PostgreSQL — Scaleway Serverless SQL Database in prod, SQLite for local dev)
# Prod:  DATABASE_URL=postgresql://<iam_key_id>:<iam_secret_key>@<sdb_endpoint>/mediatech-sync-state?sslmode=require
# Local: DATABASE_URL=sqlite:///./state.db
DATABASE_URL=sqlite:///./state.db

# Sync settings
CHUNK_BATCH_SIZE=64
REQUESTS_PER_SECOND=2.0

# Logging
LOG_LEVEL=INFO

# Tchap notifications (optional — leave blank to disable)
TCHAP_ACCESS_TOKEN=
TCHAP_ROOM_ID=
TCHAP_HOMESERVER=